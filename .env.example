# Banco BanQuito V2 - Core Account Service
# Copiar a .env local o declarar en el proveedor cloud. No subir secretos reales.

SPRING_APPLICATION_NAME=core-account-service
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8085
APP_TIMEZONE=America/Guayaquil

# Local con MySQL publicado en el host
ACCOUNT_DB_URL=jdbc:mysql://localhost:33064/banquito_core_account_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Guayaquil
ACCOUNT_DB_USER=root
ACCOUNT_DB_PASSWORD=BanQuitoRoot2026!

# Docker/cloud: usar nombres internos de servicios Docker
# ACCOUNT_DB_URL=jdbc:mysql://mysql-account:3306/banquito_core_account_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=America/Guayaquil
# ACCOUNT_DB_USER=root
# ACCOUNT_DB_PASSWORD=${MYSQL_ROOT_PASSWORD}

JWT_ISSUER=banquito-identity-access
JWT_SECRET=BanQuitoIdentityJwtSecretKeyForDevelopmentOnlyChangeMe2026

JPA_DDL_AUTO=validate
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
FLYWAY_BASELINE_VERSION=1

ACTUATOR_ENDPOINTS=health,info
ACTUATOR_HEALTH_DETAILS=always
OPENAPI_DOCS_PATH=/api-docs
SWAGGER_UI_PATH=/swagger-ui.html

DB_MAX_POOL_SIZE=10
DB_MIN_IDLE=2
DB_CONNECTION_TIMEOUT_MS=30000
HIBERNATE_FORMAT_SQL=true

# gRPC interno Core -> Core. Se implementará en la fase de integración real.
CUSTOMER_GRPC_HOST=core-customer-service
CUSTOMER_GRPC_PORT=9092
ADMIN_GRPC_HOST=core-admin-service
ADMIN_GRPC_PORT=9093
ACCOUNTING_GRPC_HOST=core-accounting-service
ACCOUNTING_GRPC_PORT=9094

# Plataforma transversal / eventos posteriores
NOTIFICATION_SERVICE_URL=http://notification-service:8087
DOCUMENT_SERVICE_URL=http://document-service:8086
BANQUITO_EVENTS_EXCHANGE=banquito.events.exchange
ACCOUNT_NOTIFICATION_ROUTING_KEY=notification.requested
ACCOUNT_DOCUMENT_ROUTING_KEY=document.requested
RECENT_TRANSACTIONS_LIMIT=20
ACCOUNTING_DATE_SOURCE=local
